# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=remplacer-par-une-cle-secrete-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=anti_plagiat
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# OCR (laisser vide sous Linux/Docker, Tesseract est dans le PATH)
TESSERACT_CMD=
POPPLER_PATH=

# Chemins Windows locaux (dev uniquement, ignorer sous Docker)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\poppler-25.12.0\Library\bin
